{
  "startChapterId": "intro",

  "chapters": {
    "intro": {
      "text": [
        "chapter.intro.text.line_1",
        "chapter.intro.text.line_2"
      ],
      "choices": [
        { "text": "chapter.intro.choice.forest", "next": "ruins" },
        { "text": "chapter.intro.choice.village", "next": "village" }
      ],
      "onEnter": {
        "effects": [
          { "type": "addVar", "id": "life", "value": 4 }
        ]
      }
    },

    "forest": {
      "text": [
        "chapter.forest.text.line_1",
        "chapter.forest.text.line_2"
      ],
      "choices": [
        { "text": "chapter.forest.choice.noise", "next": "noise" },
        { "text": "chapter.forest.choice.intro", "next": "intro" }
      ]
    },

    "village": {
      "text": [
        "chapter.village.text.line_1",
        "chapter.village.text.line_2"
      ],
      "choices": [
        { "text": "chapter.village.choice.house", "next": "house" },
        { "text": "chapter.village.choice.intro", "next": "intro" },
        { 
          "text": "chapter.village.choice.map", 
          "next": "map",
          "conditions": {
            "hasItem": "map"
          } 
        }
      ]
    },

    "noise": {
      "text": [
        "chapter.noise.text.line_1",
        "chapter.noise.text.line_2"
      ],
      "choices": [
        { "text": "chapter.noise.choice.deepForest", "next": "deepForest" }
      ]
    },

    "house": {
      "text": [
        "chapter.house.text.line_1",
        "chapter.house.text.line_2",
        "chapter.house.text.line_3"
      ],
      "choices": [
        { 
          "text": "chapter.house.choice.village",
          "next": "village"
        },
        { 
          "text": "chapter.house.choice.map", 
          "next": "map",
          "effects": [
            { "type": "addItem", "id": "map", "value": 1 }
          ],
          "conditions": {
            "hasNoItem": "map"
          } 
        },
        { 
          "text": "chapter.house.choice.torch", 
          "next": "village",
          "effects": [
            { "type": "addItem", "id": "torch", "value": 1 }
          ],          
          "conditions": {
            "all": [
              { "hasItem": "map" },
              { "hasNoItem": "torch" },
              { "visitCount": { "id": "village", "min": 2 }}
            ]
          }
        }
      ]
    },

    "deepForest": {
      "text": [
        "chapter.deepForest.text.line_1"
      ],
      "choices": [
        { "text": "chapter.deepForest.choice.mysterious_portal", "next": "mysterious_portal" }
      ]
    },

    "map": {
      "text": [
        "chapter.map.text.line_1"
      ],
      "choices": [
        { 
          "text": "chapter.map.choice.treasure", "next": "treasure"
        }
      ]
    },

    "mysterious_portal": {
      "text": [
        "chapter.mysterious_portal.text.line_1"
      ],
      "choices": [
        {
          "text": "chapter.mysterious_portal.choice.strike_with_axe",
          "conditions": {
              "variables": {
                "doorHits": { "lt": 3 }
              }
          },          
          "attempt": {
            "effects": [
              {
                "type": "addVar",
                "id": "doorHits",
                "value": {
                  "add": [
                    1
                  ]
                }
              }
            ],
            "success": {
              "conditions": {
                "variables": {
                  "doorHits": { "gte": 3 }
                }
              },
              "next": "ruins",
              "message": "Você conseguiu destruir a porta!"
            },
            "failure": {
              "effects": [
                { "type": "addVar", "id": "life", "value": -1 }
              ],
              "message": "Você se machucou tentando."
            }
          }
        },
        {
          "text": "chapter.mysterious_portal.choice.enter",
          "conditions": {
              "variables": {
                "doorHits": { "gte": 3 }
              }
          },
          "next": "ruins"
        }  
      ]
    },

    "treasure": {
      "text": [
        "chapter.treasure.text.line_1"
      ],
      "choices": [
        {
          "text": "chapter.treasure.choice.use_lockpick",
          "conditions": {
            "variables": {
              "lockPickSucess": { "lt": 30 }       
            }
          },          
          "attempt": {
            "effects": [
              {
                "type": "addVar",
                "id": "lockPickSucess",
                "value": {
                  "add": [
                    { "var": "lockPicking" },
                    1,
                    { "dice": { "count": 2, "sides": 6 } }
                  ]
                }
              }
            ],
            "success": {
              "conditions": {
                "variables": {
                  "lockPickSucess": { "gte": 30 }
                }
              },
              "effects": [
                { "type": "addItem", "id": "gold", "value": 20 }
              ],
              "next": "village",
              "message": "Você conseguiu abrir o baú!"
            },
            "failure": {
              "effects": [
                { "type": "useItem", "id": "lockpick", "value": 1 }
              ],
              "message": "Você quebrou um lockpick, ainda resta(m) {lockPick}."
            }
          }
        },
        {
          "text": "chapter.treasure.choice.village",
          "next": "village"
        }
      ]
    },

    "ruins": {
      "text": [
        "chapter.ruins.text.line_1",
        "chapter.ruins.text.line_2"
      ],
      "onEnter": {
        "effects": [
          { "type": "addVar", "id": "life", "value": -1 }
        ]
      },
      "choices": [
        { 
          "text": "chapter.ruins.choice.intro", 
          "next": "intro"
        },
        { 
          "text": "chapter.ruins.choice.ruins_door", 
          "next": "ruins_door",
          "conditions": {
            "all": [
              { "hasItem": "torch" },
              { "itemCount": { "id": "torch", "min": 1 } },
              { "hasVisited": "village"},
              { "visitCount": { "id": "village", "min": 2 }}
            ]
          }
        }
      ]
    },

    "ruins_door": {
      "text": [
        "chapter.ruins_door.text.line_1",
        "chapter.ruins_door.text.line_2"
      ],
      "choices": [
        {
          "text": "chapter.mysterious_portal.choice.strike_with_axe",
          "attempt": {
            "effects": { 
              "increment": { "doorHits": 1 } 
            },
            "success": {
              "conditions": {
                "variables": { "doorHits": 3 }
              },
              "next": "porta_aberta"
            },
            "failure": {
              "message": "Ainda não abriu."
            }
          }
        }
      ]
    }
  }
}
